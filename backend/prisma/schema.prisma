generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(uuid())
  name                String
  email               String    @unique
  passwordHash        String
  role                String    @default("OWNER")
  atelierName         String?
  phone               String?
  logoUrl             String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  isVerified          Boolean   @default(false)
  verificationCode    String?
  verificationExpires DateTime?
  clients             Client[]
  coupons             Coupon[]
  orders              Order[]
  receipts            Receipt[]

  @@map("users")
}

model Client {
  id            String         @id @default(uuid())
  userId        String
  name          String
  email         String?
  phone         String?
  cpfCnpj       String?
  address       String?
  birthDate     DateTime?
  notes         String?
  measures      Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifications Notification[]
  orders        Order[]

  @@map("clients")
}

model Order {
  id               String         @id @default(uuid())
  orderNumber      String         @unique
  userId           String
  clientId         String
  status           OrderStatus    @default(DRAFT)
  title            String
  description      String?
  notes            String?
  dueDate          DateTime?
  deliveredAt      DateTime?
  paidAt           DateTime?
  totalAmount      Decimal        @default(0) @db.Decimal(10, 2)
  deposit          Decimal        @default(0) @db.Decimal(10, 2)
  discount         Decimal        @default(0) @db.Decimal(10, 2)
  paymentMethod    PaymentMethod?
  paymentNotes     String?
  validationResult Json?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  notifications    Notification[]
  items            OrderItem[]
  client           Client         @relation(fields: [clientId], references: [id])
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  receipt          Receipt?

  @@map("orders")
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  description String
  fabric      String?
  quantity    Decimal  @default(1) @db.Decimal(10, 3)
  unitPrice   Decimal  @db.Decimal(10, 2)
  subtotal    Decimal  @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model Receipt {
  id            String        @id @default(uuid())
  userId        String
  orderId       String        @unique
  receiptNumber String        @unique
  issuedAt      DateTime      @default(now())
  totalAmount   Decimal       @db.Decimal(10, 2)
  amountInWords String
  paymentMethod PaymentMethod
  pdfPath       String?
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("receipts")
}

model Coupon {
  id            String     @id @default(uuid())
  userId        String
  code          String     @unique
  type          CouponType
  value         Decimal    @db.Decimal(10, 2)
  description   String
  isActive      Boolean    @default(true)
  clientId      String?
  minOrderValue Decimal?   @db.Decimal(10, 2)
  usedAt        DateTime?
  expiresAt     DateTime?
  createdAt     DateTime   @default(now())
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("coupons")
}

model Notification {
  id        String              @id @default(uuid())
  orderId   String?
  clientId  String?
  channel   NotificationChannel
  type      String
  message   String
  status    String              @default("PENDING")
  sentAt    DateTime?
  error     String?
  createdAt DateTime            @default(now())
  client    Client?             @relation(fields: [clientId], references: [id])
  order     Order?              @relation(fields: [orderId], references: [id])

  @@map("notifications")
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  IN_PRODUCTION
  READY
  DELIVERED
  PAID
  CANCELLED
  ARCHIVED
}

enum PaymentMethod {
  CASH
  PIX
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  OTHER
}

enum CouponType {
  FREE_SHIPPING
  PERCENTAGE
  FIXED_VALUE
}

enum NotificationChannel {
  WHATSAPP
  EMAIL
  SMS
}
